# ============================================================
# LOCAL DEV SECRETS TEMPLATE
# ============================================================
# 1. Copy this file and rename the copy to:
#      application-secrets.properties
#    (remove the ".example" part)
# 2. Fill in your REAL values below in the copy.
# 3. Never rename/edit THIS file with real secrets — this one
#    (the .example) is the only one that gets committed to Git.
#    The renamed copy is already git-ignored, so it's safe.
#
# In production (Render/Railway/EC2/etc.) you won't use this file
# at all — you'll set these same names as real environment
# variables in your hosting platform's dashboard instead.
# ============================================================

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nestbites?retryWrites=true&w=majority
JWT_SECRET=paste-a-long-random-string-here

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
